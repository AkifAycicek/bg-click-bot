{
  "name": "bg_clicker_bot",
  "version": "0.1.1",
  "main": "app/main.js",
  "scripts": {
    "start": "node bot.js",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:renderer": "vite build",
    "build:electron": "electron-builder --win",
    "build:app": "npm run build:renderer && npm run build:electron",
    "test": "node --test --test-timeout=30000 tests/bot.test.js tests/presets.test.js",
    "test:ui": "vitest run",
    "test:e2e": "npx vite build && playwright test",
    "test:all": "npm test && npm run test:ui && npm run test:e2e",
    "prebuild": "npm test && npm run test:ui && npm run test:e2e",
    "build": "node build.js && npm run build:app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AkifAycicek/bg-click-bot.git"
  },
  "homepage": "https://github.com/AkifAycicek/bg-click-bot",
  "keywords": [
    "clicker",
    "auto-clicker",
    "background",
    "bot",
    "electron"
  ],
  "author": "Akif Aycicek",
  "license": "MIT",
  "description": "Background auto-clicker bot with multi-tab preset support, window thumbnails, and global hotkeys",
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "koffi": "^2.15.2",
    "postcss": "^8.5.8",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
